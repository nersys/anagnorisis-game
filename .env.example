# Anagnorisis Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Claude API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI API Key — optional, enables DALL-E scene art (get from https://platform.openai.com/api-keys)
# If not set, scene art returns an error (client falls back to Pollinations.ai)
OPENAI_API_KEY=your-openai-key-here

# Set to true to use DALL-E 3 instead of the default DALL-E 2.
# Remove or leave blank to use DALL-E 2.
# USE_DALLE_3=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./anagnorisis.db

# Game Settings
GAME_TICK_SECONDS=60
DEBUG=true
