# Anagnorisis Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Claude API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI API Key — optional, enables DALL-E 3 scene art (get from https://platform.openai.com/api-keys)
# If not set, scene art falls back to Claude SVG generation
OPENAI_API_KEY=your-openai-key-here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./anagnorisis.db

# Game Settings
GAME_TICK_SECONDS=60
DEBUG=true
